# Choose how Synora analyzes live Polymarket data:
# - ollama: local/open LLM, free if you run Ollama yourself
# - anthropic: hosted Claude + web search, requires ANTHROPIC_API_KEY
# - quant: deterministic analysis from Polymarket data only
# - auto: Anthropic if configured, then Ollama if configured, then quant
AI_PROVIDER=ollama

# Local open LLM mode. Start Ollama separately, then pull a model such as:
# ollama pull qwen2.5:7b-instruct
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen2.5:7b-instruct

# Optional hosted AI mode.
ANTHROPIC_API_KEY=

# Web3 — app URL used in WalletConnect metadata (defaults to localhost in dev).
NEXT_PUBLIC_APP_URL=http://localhost:3000

# WalletConnect project ID (optional; MetaMask/Coinbase work without it).
# Get a free ID at https://cloud.walletconnect.com
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=
